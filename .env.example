# Public browser configuration. The anon key is intentionally public and must
# still be protected by correct Supabase RLS policies.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this through a NEXT_PUBLIC_* variable.
SUPABASE_SERVICE_ROLE_KEY=

# Optional deployment URLs.
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SITE_URL=

# Local test use only. Never enable in staging or production.
NEXT_PUBLIC_DISABLE_AUTH_FOR_TESTING=false

# Clinic demo seeding only.
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=
